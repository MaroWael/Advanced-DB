<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="umsPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.example.ums.entity.User</class>
        <class>org.example.ums.entity.Student</class>
        <class>org.example.ums.entity.Instructor</class>
        <class>org.example.ums.entity.Admin</class>
        <class>org.example.ums.entity.Course</class>
        <class>org.example.ums.entity.Quiz</class>
        <class>org.example.ums.entity.Question</class>
        <class>org.example.ums.entity.QuizResult</class>
        <class>org.example.ums.entity.QuizAnswer</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://127.0.0.1:3306/ums_db?useSSL=false"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

    <persistence-unit name="umsTestPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.example.ums.entity.User</class>
        <class>org.example.ums.entity.Student</class>
        <class>org.example.ums.entity.Instructor</class>
        <class>org.example.ums.entity.Admin</class>
        <class>org.example.ums.entity.Course</class>
        <class>org.example.ums.entity.Quiz</class>
        <class>org.example.ums.entity.Question</class>
        <class>org.example.ums.entity.QuizResult</class>
        <class>org.example.ums.entity.QuizAnswer</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:ums_test;MODE=MySQL;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

</persistence>

